DJANGO_SECRET_KEY=change-this-to-a-long-random-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=.onrender.com,awsccflurr.me,www.awsccflurr.me,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com,https://awsccflurr.me,https://www.awsccflurr.me
DJANGO_ALLOW_ALL_HOSTS_ON_RENDER=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
RENDER_EXTERNAL_HOSTNAME=
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Optional: store uploaded media (profile pictures, showcase images) on S3
USE_S3_MEDIA=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
# Optional custom domain (CloudFront or S3 website/domain)
AWS_S3_CUSTOM_DOMAIN=
# Set to True if you use private bucket objects and signed URLs
AWS_QUERYSTRING_AUTH=False

EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=10
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=SG.your-sendgrid-api-key-here
DEFAULT_FROM_EMAIL=Flurry <noreply@yourdomain.com>
