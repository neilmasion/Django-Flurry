DJANGO_SECRET_KEY=change-this-to-a-long-random-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=.railway.app,.onrender.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app,https://your-app.onrender.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True

# Render auto-sets this when deployed there
RENDER_EXTERNAL_HOSTNAME=

# Neon Postgres
# Include sslmode=require in the URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Flurry <your-email@gmail.com>
